# 🖥️ Server Configuration
BACKEND_PORT=8000
FRONTEND_PORT=3000
DATABASE_URL=sqlite:///./launchpad.db
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# 🔑 REQUIRED API KEYS
# Get your Gemini API key from: https://aistudio.google.com/app/apikey
GOOGLE_GEMINI_API_KEY=your_gemini_api_key_here

# Get FRED API key from: https://fredaccount.stlouisfed.org/account/signup
FRED_API_KEY=your_fred_api_key_here

# 💳 Square Integration (Optional - Sandbox)
# Get credentials from: https://developer.squareup.com
SQUARE_ACCESS_TOKEN=your_square_access_token_here
SQUARE_ENVIRONMENT=sandbox

# 🤖 Optional - Backboard API
# Get from: https://backboard.io
BACKBOARD_API_KEY=your_backboard_api_key_here

# Optional - BestTime API for foot traffic analysis
# Get from: https://besttime.app
BESTTIME_API_KEY=your_besttime_api_key_here
BESTTIME_PUBLIC_KEY=your_besttime_public_key_here

# Optional - Mapbox for location visualization
# Get from: https://www.mapbox.com
NEXT_PUBLIC_MAPBOX_TOKEN=your_mapbox_token_here

# 📡 Free Public APIs (No keys required - already configured)
BOC_API_ENABLED=true
STATCAN_API_ENABLED=true
REACTFLOW_ENABLED=true
UPCITEMDB_ENABLED=true
