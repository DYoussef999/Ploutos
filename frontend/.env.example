# Auth0 Configuration
# Get credentials from: https://manage.auth0.com/dashboard
NEXT_PUBLIC_AUTH0_DOMAIN=your_domain.us.auth0.com
NEXT_PUBLIC_AUTH0_CLIENT_ID=your_client_id_here
AUTH0_BASE_URL=http://localhost:3000
AUTH0_SECRET=generate_with_node_-e_crypto.randomBytes_32.toString_hex

# Backend API
# If running backend locally on port 8000:
NEXT_PUBLIC_API_URL=http://localhost:8000

# Optional - Mapbox for interactive maps
# Get from: https://www.mapbox.com
NEXT_PUBLIC_MAPBOX_TOKEN=your_mapbox_token_here
